<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <link name="base_link"/>

    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_link"/>
        <child link="base_footprint"/>
        <origin xyz="0 0 -0.13" rpy="0 0 0"/>
    </joint>

    <link name="base_footprint"/>

    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="chassis_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://amr_sweeper_description/meshes/chassis/v2025_09/chassis_assembly.stl"/>
            </geometry>
            <material name="grey"/>
        </visual>
        <!--
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://amr_sweeper_description/meshes/chassis/v2025_09/chassis_assembly.stl"/>
            </geometry>
        </collision>
        -->
        <inertial>
            <origin xyz="0.054 0 0.110" rpy="0 0 0"/>
            <mass value="15.4"/>
            <inertia ixx="0.2" ixy="0.002" ixz="-0.010" iyy="0.376" iyz="0.000" izz="0.508"/>
        </inertial>
    </link>

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <origin xyz="0 0.244 0" rpy="-${pi/2} 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="left_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
            <geometry>
                <mesh filename="package://amr_sweeper_description/meshes/wheel_assembly/v2025_09/wheel_assembly.stl"/>
            </geometry>
            <material name="yellow"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
            <geometry>
                <mesh filename="package://amr_sweeper_description/meshes/wheel_assembly/v2025_09/wheel_assembly.stl"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.5"/>
            <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.01"/>
        </inertial>
    </link>

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <origin xyz="0 -0.244 0" rpy="${pi/2} 0 0"/>
        <axis xyz="0 0 -1"/>
    </joint>

    <link name="right_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
            <geometry>
                <mesh filename="package://amr_sweeper_description/meshes/wheel_assembly/v2025_09/wheel_assembly.stl"/>
            </geometry>
            <material name="yellow"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
            <geometry>
                <mesh filename="package://amr_sweeper_description/meshes/wheel_assembly/v2025_09/wheel_assembly.stl"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.5"/>
            <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.01"/>
        </inertial>
    </link>

    <joint name="tool_joint" type="fixed">
        <origin xyz="0.33 0 0.075" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="tool_link"/>
        <axis xyz="1 0 0"/>
        <!--<limit lower="-${pi/18}" upper="${pi/18}" velocity="100" effort="100"/>-->
    </joint>

    <link name="tool_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://amr_sweeper_description/meshes/tool/v2025_09/tool_mount.stl"/>
            </geometry>
            <material name="black"/>
        </visual>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="2.5"/>
            <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.01"/>
        </inertial>
    </link>

    <joint name="left_brush_joint" type="fixed">
        <origin xyz="0 -0.155 -0.073" rpy="0 0 0"/>
        <parent link="tool_link"/>
        <child link="left_brush_link"/>
    </joint>

    <link name="left_brush_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://amr_sweeper_description/meshes/tool/v2025_09/nylon_brush.stl"/>
            </geometry>
            <material name="red"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://amr_sweeper_description/meshes/tool/v2025_09/nylon_brush.stl"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.5"/>
            <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.01"/>
        </inertial>
    </link>

    <joint name="right_brush_joint" type="fixed">
        <origin xyz="0 0.155 -0.073" rpy="0 0 0"/>
        <parent link="tool_link"/>
        <child link="right_brush_link"/>
    </joint>

    <link name="right_brush_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://amr_sweeper_description/meshes/tool/v2025_09/nylon_brush.stl"/>
            </geometry>
            <material name="red"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://amr_sweeper_description/meshes/tool/v2025_09/nylon_brush.stl"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.5"/>
            <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.01"/>
        </inertial>
    </link>

</robot>
